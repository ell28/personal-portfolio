---
import type { Project } from '../data/site';
interface Props {
  project: Project;
}
const { project } = Astro.props;
const initial = project.title.replace(/[^A-Za-z0-9]/g, '').charAt(0).toUpperCase();
const fit = project.imageFit ?? 'contain';
---

<article class="card">
  <div class="card-media" data-fit={fit}>
    {
      project.image ? (
        <img
          class="card-shot"
          src={project.image}
          alt={`${project.title} screenshot`}
          loading="lazy"
        />
      ) : (
        <span class="card-tile" aria-hidden="true">
          {initial}
        </span>
      )
    }
  </div>

  <div class="card-body">
    <div class="card-head">
      <h3 class="card-title">{project.title}</h3>
      {project.year && <span class="card-year muted">{project.year}</span>}
    </div>

    <p class="card-desc">{project.description}</p>

    {
      project.tags.length > 0 && (
        <div class="tag-row card-tags">
          {project.tags.map((t) => (
            <span class="chip">{t}</span>
          ))}
        </div>
      )
    }

    {
      (project.link || project.repo) && (
        <div class="card-links">
          {project.link && (
            <a href={project.link} target="_blank" rel="noopener noreferrer">
              {project.linkLabel ?? 'Live'} ↗
            </a>
          )}
          {project.repo && (
            <a href={project.repo} target="_blank" rel="noopener noreferrer">
              Code ↗
            </a>
          )}
        </div>
      )
    }
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 0.2s var(--ease), transform 0.2s var(--ease),
      box-shadow 0.2s var(--ease);
  }
  .card:hover {
    border-color: var(--border-strong);
    transform: translateY(-3px);
    box-shadow: 0 14px 34px -20px rgba(0, 0, 0, 0.28);
  }

  /* Media area — screenshot or app-tile fallback */
  .card-media {
    position: relative;
    aspect-ratio: 4 / 3;
    display: grid;
    place-items: center;
    padding: 1rem;
    background: radial-gradient(
      130% 130% at 50% 0%,
      var(--accent-wash),
      var(--bg-subtle)
    );
    border-bottom: 1px solid var(--border);
    overflow: hidden;
  }
  .card-shot {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    border-radius: 10px;
    box-shadow: 0 12px 30px -12px rgba(0, 0, 0, 0.4);
  }
  /* 'cover' → fill the whole media area, anchored to the top of the screen */
  .card-media[data-fit='cover'] {
    padding: 0;
  }
  .card-media[data-fit='cover'] .card-shot {
    width: 100%;
    height: 100%;
    max-width: none;
    max-height: none;
    object-fit: cover;
    object-position: top center;
    border-radius: 0;
    box-shadow: none;
  }
  .card-tile {
    font-size: 2.75rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--accent-ink);
    opacity: 0.9;
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.4rem 1.5rem;
  }
  .card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .card-title {
    font-size: 1.15rem;
  }
  .card-year {
    font-size: 0.85rem;
    white-space: nowrap;
  }
  .card-desc {
    color: var(--ink-soft);
    font-size: 0.98rem;
    margin: 0 0 1.1rem;
  }
  .card-tags {
    margin-top: auto;
  }
  .card-links {
    display: flex;
    gap: 1.1rem;
    margin-top: 1.1rem;
    padding-top: 1.1rem;
    border-top: 1px solid var(--border);
    font-size: 0.9rem;
    font-weight: 500;
  }
</style>
